# Environment Configuration File
# Copy this file to .env.local and update with your values

# Base URL for the application
BASE_URL=https://demo.prestashop.com

# Environment type: staging, production, development
ENVIRONMENT=staging

# Test timeout in milliseconds
TIMEOUT=30000

# Number of retries for failed tests
RETRY_COUNT=2

# Slow motion mode (in ms) - 0 to disable
SLOW_MO=0

# Run tests in headless mode
HEADLESS=true

# Test browser
BROWSER=chromium

# Parallel workers for test execution
WORKERS=4

# Video recording: never, only-on-failure, retain-on-failure
VIDEO=only-on-failure

# Screenshot: never, only-on-failure, retain-on-failure
SCREENSHOT=only-on-failure

# Trace recording: never, on-first-retry, on-all-retries, retain-on-failure
TRACE=on-first-retry
